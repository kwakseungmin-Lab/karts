# karts — Environment Configuration Example
# Copy this file to .env and fill in any optional keys you want to enable.
# All paid cloud APIs have been removed. The tools below run locally or use
# free-tier services that do not require payment.

# ============================================================
# 오픈소스 도구 (API 키 불필요 — 로컬 실행)
# ============================================================
VIDEO_GEN_LOCAL_ENABLED=true

# ============================================================
# 무료 미디어 API (선택 — 없으면 로컬 생성으로 폴백)
# ============================================================

# Pexels (무료 영상/이미지 검색)
PEXELS_API_KEY=

# Pixabay (무료 영상/이미지/음악 검색)
PIXABAY_API_KEY=

# Freesound (무료 CC 음악·음향 — suno_music 폴백 대상)
FREESOUND_API_KEY=

# ============================================================
# 제거된 유료 API (사용 불가 — 참고용으로만 남김)
# ============================================================
# FAL_KEY=              # fal.ai — Kling, MiniMax, Veo, Seedance, Recraft, FLUX (제거됨)
# RUNWAY_API_KEY=       # Runway ML (제거됨)
# XAI_API_KEY=          # xAI Grok video/image (제거됨)
# HIGGSFIELD_API_KEY=   # Higgsfield Cloud (제거됨)
# HIGGSFIELD_API_SECRET=
# HEYGEN_API_KEY=       # HeyGen (제거됨)
# OPENAI_API_KEY=       # OpenAI DALL-E (제거됨)
# GOOGLE_API_KEY=       # Google Imagen (제거됨)
# ELEVENLABS_API_KEY=   # ElevenLabs TTS/Music (제거됨)
# DOUBAO_SPEECH_API_KEY= # ByteDance Doubao Speech (제거됨)
# SUNO_API_KEY=         # Suno AI music (제거됨)
